target uC

import Count, Print from "Federated.lf"

reactor PrintTimer extends Print {
    timer t(0, 1 sec)

    reaction(t) {=
        instant_t elapsed = env->get_elapsed_logical_time(env);
        printf("Timer ticked at %lld\n", elapsed);
    =}
}

@platform("native")
@timeout(5sec)
federated reactor {
    c = new Count()
    @maxwait(10 ms)
    p = new PrintTimer()
    c.out -> p.in
}
