target uC

reactor Count {
  output out: int
  state c: int = 0
  timer t(0, 1 sec)

  reaction(t) -> out {=
    lf_set(out, self->c++);
  =}
}

reactor Print {
  input in: int

  reaction(in) {=
    instant_t current_tag = env->get_logical_time(env);
    printf("Received: %d at %lld\n", in->value, current_tag);
  =}
}

@platform("native")
@timeout(5sec)
federated reactor {
  c = new Count()
  p = new Print()
  c.out -> p.in
}
