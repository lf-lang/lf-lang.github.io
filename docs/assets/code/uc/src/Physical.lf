target uC;
reactor Physical {
  input x:int;
  @max_pending_events(1)
  physical action a;
  reaction(x) -> a {=
    lf_schedule(a, 0);
  =}
  reaction(a) {=
    interval_t elapsed_time = env->get_elapsed_logical_time(env);
    printf("Action triggered at logical time %lld nsec after start.\n", elapsed_time);
  =}
}
