target uC

import Count from "../Count.lf";
import Scale from "../Scale.lf";
import TestCount from "../TestCount.lf";

@platform("Native")
@timeout(1 sec)
@fast(true)
main reactor {
    c = new Count();
    d = new Scale();
    t = new TestCount(start = 0, stride = 2, num_inputs = 11);
    c.y -> d.x;
    d.y -> t.x;
}