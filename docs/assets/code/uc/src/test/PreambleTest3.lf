/**
 * This example is included in Preambles.md, but not automatically imported.
 * Success of the test is compiling and running.
 */
target uC
import Cos from "../lib/Cos.lf"
preamble {=
    #include <math.h>
=}
reactor Sin {
    reaction(startup) {=
        printf("The sine of 1 is %f.\n", sin(1));
    =}
}
@platform("Native")
main reactor {
    c = new Cos()
    s = new Sin()
}
