/**
 * This example is included in Preambles.md, but not automatically imported.
 * Success of the test is compiling and running.
 */
target uC
preamble {=
    typedef int foo;
=}
@platform("Native")
main reactor {
    state x:foo = 0
    reaction(startup) {=
        printf("State is %d\n", self->x);
    =}
}